{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping the SafeCloud node_exporter",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "SafeCloud.PRO — Hardened LEMP Host",
  "uid": "safecloud-lemp-host",
  "tags": ["safecloud", "node-exporter", "lemp"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": "${datasource}",
        "query": "label_values(node_uname_info, instance)",
        "refresh": 2,
        "includeAll": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU usage",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\", instance=\"$instance\"}[5m])) * 100)",
          "legendFormat": "cpu busy %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Memory used %",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "(1 - (node_memory_MemAvailable_bytes{instance=\"$instance\"} / node_memory_MemTotal_bytes{instance=\"$instance\"})) * 100",
          "legendFormat": "memory used %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Load average (1m / 5m / 15m)",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "targets": [
        { "datasource": "${datasource}", "expr": "node_load1{instance=\"$instance\"}",  "legendFormat": "1m",  "refId": "A" },
        { "datasource": "${datasource}", "expr": "node_load5{instance=\"$instance\"}",  "legendFormat": "5m",  "refId": "B" },
        { "datasource": "${datasource}", "expr": "node_load15{instance=\"$instance\"}", "legendFormat": "15m", "refId": "C" }
      ]
    },
    {
      "id": 4,
      "title": "Root filesystem free",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "(node_filesystem_avail_bytes{instance=\"$instance\", mountpoint=\"/\"} / node_filesystem_size_bytes{instance=\"$instance\", mountpoint=\"/\"}) * 100",
          "legendFormat": "root free %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Network I/O (eth0)",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        { "datasource": "${datasource}", "expr": "rate(node_network_receive_bytes_total{instance=\"$instance\", device=\"eth0\"}[5m])",  "legendFormat": "rx", "refId": "A" },
        { "datasource": "${datasource}", "expr": "rate(node_network_transmit_bytes_total{instance=\"$instance\", device=\"eth0\"}[5m])", "legendFormat": "tx", "refId": "B" }
      ]
    },
    {
      "id": 6,
      "title": "Uptime",
      "type": "stat",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "node_time_seconds{instance=\"$instance\"} - node_boot_time_seconds{instance=\"$instance\"}",
          "legendFormat": "uptime",
          "refId": "A"
        }
      ]
    }
  ]
}
