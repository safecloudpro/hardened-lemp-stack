# ==============================================================================
# SafeCloud.PRO - Hardened WordPress/LEMP Stack Environment Configuration Template
# Place this file in your server administrative root or repository root as '.env'
# DO NOT COMMIT THE ACTUAL '.env' FILE TO SOURCE CONTROL!
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DATABASE CONFIGURATION (MariaDB 11.x)
# ------------------------------------------------------------------------------
# Ensure the database name, user, and password are highly secure and unique.
# The user specified here should have least-privilege permissions (no FILE privilege).
DB_NAME=wordpress_db
DB_USER=safecloud_wp_user
DB_PASSWORD=ChangeMe_To_A_Highly_Secure_32_Character_String_With_Symbols!
DB_HOST=127.0.0.1
DB_PORT=3306

# ------------------------------------------------------------------------------
# 2. CACHING CONFIGURATION (Redis)
# ------------------------------------------------------------------------------
# Your deployment utilizes direct Unix socket memory pipes.
# If your WordPress Object Cache plugin supports a socket password, specify it here.
REDIS_SCHEME=unix
REDIS_PATH=/var/run/redis/redis-server.sock
REDIS_PASSWORD=ChangeMe_To_A_Secure_Object_Cache_Password_If_Enforced!

# ------------------------------------------------------------------------------
# 3. SPAM PROTECTION CONFIGURATION (Cloudflare Turnstile)
# ------------------------------------------------------------------------------
# Register your domain at dash.cloudflare.com to obtain Turnstile credentials.
# The Site Key is public (used in frontend HTML). The Secret Key must remain private.
CLOUDFLARE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
CLOUDFLARE_TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000000000000

# ------------------------------------------------------------------------------
# 4. PAYMENT GATEWAY WEBHOOK CRYPTOGRAPHIC SECRETS
# ------------------------------------------------------------------------------
# Secure webhook signatures prevent replay attacks and payload manipulation.
# Retrieve these directly from your Stripe and PayPal merchant dashboards.
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_signing_secret_here
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here

# ------------------------------------------------------------------------------
# 5. MONITORING, ALERTING & METRICS TELEMETRY
# ------------------------------------------------------------------------------
# Discord/Slack webhook consumed by scripts/alert-apparmor-status.sh and
# scripts/fail2ban-report.sh for security alert dispatches.
ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# The node exporter is isolated to localhost (127.0.0.1:9100) by default.
# If you front Prometheus with basic authentication, keep credentials here.
PROMETHEUS_ADMIN_USER=admin
PROMETHEUS_ADMIN_HASH=$2b$12$YourBcryptPasswordHashForPrometheusAuthenticationHere

# ------------------------------------------------------------------------------
# 6. DEPLOYMENT PARAMETERS (OPTIONAL — records the setup.sh flags you deploy with)
# ------------------------------------------------------------------------------
# By DEFAULT setup.sh auto-sizes EVERY memory setting (PHP-FPM worker count,
# InnoDB buffer pool, Redis cap, system reserve) from the RAM the host actually
# has, so the normal invocation passes no sizing flags at all:
#   sudo ./setup.sh -y
#
# The two variables below are OPTIONAL pins — set them only to override the
# auto-sizing on a specific host, then record the values here so audits and
# re-provisioning stay reproducible:
#   sudo ./setup.sh -y --php-workers "${LEMP_PHP_WORKERS}" --db-pool "${LEMP_DB_POOL_SIZE}"
# Leave them commented out to keep the RAM-adaptive defaults (recommended).
#LEMP_PHP_WORKERS=120
#LEMP_DB_POOL_SIZE=1.5G
LEMP_INSTALL_LOG=/var/log/lemp_interactive_install.log
